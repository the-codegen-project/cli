{
  "$id": "StockUpdated",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["productId", "previousQuantity", "newQuantity"],
  "properties": {
    "productId": {
      "type": "string"
    },
    "previousQuantity": {
      "type": "integer"
    },
    "newQuantity": {
      "type": "integer"
    },
    "reason": {
      "type": "string",
      "enum": ["sale", "restock", "adjustment", "return"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
