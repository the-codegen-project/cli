{
    "asyncapi": "2.0.0",
    "info": {
        "title": "Minimal Repro",
        "version": "0.1.0"
    },
    "defaultContentType": "application/json",
    "channels": {
        "test.{type}": {
            "parameters": {
                "type": {
                    "schema": { "type": "string" }
                }
            },
            "subscribe": {
                "operationId": "startRun",
                "message": {
                    "$ref": "#/components/messages/startRun"
                }
            }
        }
    },
    "components": {
        "messages": {
            "startRun": {
                "name": "startRun",
                "schemaFormat": "application/schema+json;version=draft-07",
                "payload": {
                    "$ref": "#/components/schemas/startRun"
                }
            }
        },
        "schemas": {
            "startRun": {
                "type": "object",
                "properties": {
                    "openapi": {
                        "$id": "OpenAPIGenerator",
                        "type": "object",
                        "properties": {
                            "language": {
                                "type": "string"
                            }
                        },
                        "allOf": [
                            {
                                "if": {
                                    "properties": {
                                        "language": { "const": "typescript-fetch" }
                                    }
                                },
                                "then": {
                                    "properties": {
                                        "typeScriptFetchSettings": {
                                            "$id": "openapi_typescript_fetch",
                                            "type": "object",
                                            "properties": {
                                                "allowUnicodeIdentifiers": {
                                                    "type": "boolean",
                                                    "default": false
                                                },
                                                "paramNaming": {
                                                    "type": "string",
                                                    "enum": ["camelCase", "PascalCase"]
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        ]
                    },
                    "the-codegen-project": {
                        "$id": "TheCodegenProjectGenerator",
                        "type": "object",
                        "properties": {
                            "generatorVersion": {
                                "type": "string",
                                "enum": ["7.9"]
                            }
                        }
                    }
                }
            }
        }
    }
}
